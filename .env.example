# Environment Configuration for Paw Print Profile

# Environment Detection
IS_LOCAL=true
LOCALSTACK_HOSTNAME=localstack
AWS_REGION=us-east-1

# LocalStack requires dummy credentials for local development
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Service Endpoints (LocalStack)
DYNAMODB_ENDPOINT=http://localstack:4566
S3_ENDPOINT=http://localstack:4566
COGNITO_ENDPOINT=http://localstack:4566
SNS_ENDPOINT=http://localstack:4566

# Application Configuration
DYNAMODB_TABLE=VetPetRegistry
S3_BUCKET=paw-print-profile-images
NODE_ENV=development

# Frontend Configuration
VITE_API_URL=http://localhost:3000
VITE_IS_LOCAL=true