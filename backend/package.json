{
  "name": "paw-print-profile-backend",
  "version": "1.0.0",
  "description": "Backend services for Paw Print Profile",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --reporter=verbose",
    "test:property": "vitest run --reporter=verbose tests/*.property.test.ts",
    "test:integration": "vitest run --reporter=verbose tests/*.integration.test.ts",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "paw-print-profile",
    "veterinary",
    "pet",
    "registry",
    "serverless",
    "aws"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.490.0",
    "@aws-sdk/client-dynamodb": "^3.490.0",
    "@aws-sdk/client-s3": "^3.490.0",
    "@aws-sdk/client-sns": "^3.490.0",
    "@aws-sdk/lib-dynamodb": "^3.490.0",
    "@aws-sdk/s3-request-presigner": "^3.1032.0",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "pdfkit": "^0.14.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.160",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/pdfkit": "^0.13.3",
    "@types/uuid": "^9.0.7",
    "@vitest/coverage-v8": "^1.1.0",
    "fast-check": "^3.15.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  }
}
